# Athena Configuration Template
# Copy this file to .env and fill with your real tokens (do NOT commit .env)
# Only the keys below are actually read by src/*.js — other vars in the old template
# were reserved for the planned SQLite migration and dashboard features that are
# not yet wired up. See README.md → "Configuration" for the full reference.

# ===========================================
# REQUIRED DISCORD CONFIGURATION
# ===========================================
DISCORD_TOKEN=your-discord-bot-token-here
CLIENT_ID=your-application-client-id
GUILD_ID=your-test-guild-id

# ===========================================
# OPTIONAL AI INTEGRATION
# ===========================================
# Cloud: OpenAI (used by /ai, /chat when OPENAI_API_KEY is set)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Local model: any OpenAI-compatible endpoint (llama.cpp, vLLM, Open WebUI, etc.)
LOCAL_MODEL_URL=http://host.docker.internal:11434/v1
LOCAL_MODEL_API=openai-compatible
LOCAL_MODEL_NAME=default-model
LOCAL_MODEL_TOKEN=not-needed

# Open WebUI: alternative path shape used by src/chat.js + src/model-client.js
# When set, the bot posts to `${OPENWEBUI_BASE}${OPENWEBUI_PATH}` instead of
# the standard OpenAI shape. Leave blank to use the OpenAI-compatible default.
OPENWEBUI_BASE=
OPENWEBUI_PATH=/api/chat

# AI behaviour knobs
AI_MAX_TOKENS=512
AI_TEMPERATURE=0.8

# Per-user chat limits (used by src/chat.js)
CHAT_COOLDOWN_MS=2000
CHAT_MAX_HISTORY=8
MAX_PROMPT_LENGTH=1000
MAX_RESPONSE_LENGTH=2000

# ===========================================
# OPTIONAL MUSIC API CREDENTIALS
# ===========================================
# Spotify: primary music source. Without these, the bot falls back to YouTube
# search and Deezer previews (no Spotify track metadata).
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here

# ===========================================
# OPTIONAL EXTERNAL APIS
# ===========================================
# /weather command — OpenWeatherMap
OPENWEATHER_API_KEY=your-openweather-api-key-here

# ===========================================
# BOT CONFIGURATION
# ===========================================
# Bot presence (used by src/index.js)
BOT_ACTIVITY=Playing RPG Adventures
BOT_STATUS=online

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV=production
DEBUG=false
